DISCORD_TOKEN=your_discord_bot_token_here
# Optional: comma-separated guild snowflakes — slash commands register per-server (fast). Omit for global commands.
# DISCORD_GUILD_ID=123456789012345678,987654321098765432
# Kurumi text: enable Message Content Intent in Developer Portal → Bot, then:
# USE_MESSAGE_CONTENT_INTENT=1
# “kurumi what time” uses this IANA zone when no /dailywordle schedule (India = Asia/Kolkata IST).
# DEFAULT_TIMEZONE=Asia/Kolkata
